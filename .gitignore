# Python virtual environment
.venv/
**/.venv/
__pycache__/
*.py[cod]

# Environment and secrets
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# Local agent/app state
.claude/settings.local.json*
.claude/worktrees/
.claude
CLAUDE.md
# PDF documents
*.pdf
**/*.pdf

# App-generated data
ai/model/data/
# Temporary files for bulk validation background jobs
ai/backend/jobs_temp/

# Supabase CLI working directory (generated, bukan source of truth)
# Source of truth migration ada di database/supabase/migrations/
# Pakai /supabase/ (dengan slash depan) agar hanya root-level yang diabaikan,
# tidak menimpa database/supabase/ yang merupakan source of truth.
/supabase/
