# Python cache and virtualenv
__pycache__/
*.py[cod]
.venv/
venv/

# Environment files
.env
.env.*
!.env*.example

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Generated extraction output (folder data/ diizinkan agar asset statis ikut ter-push)
