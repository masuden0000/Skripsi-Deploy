PORT=4000

# CORS — local dev
FRONTEND_URL=http://127.0.0.1:3000
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.100.10:3000
# CORS — Railway: isi dengan domain public frontend di Railway, contoh:
# FRONTEND_URL=https://frontend.railway.app
# FRONTEND_URLS=https://frontend.railway.app

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

SESSION_SECRET=replace_with_a_long_random_secret
SESSION_COOKIE_NAME=app_session

# AI service URL — local dev
AI_BACKEND_URL=http://127.0.0.1:8000
# AI service URL — Railway (private network, lebih cepat & tanpa biaya egress)
# AI_BACKEND_URL=http://ai.railway.internal:${{ai.PORT}}
