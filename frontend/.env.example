# Copy this file to .env.local for local frontend development.
#
# Frontend berbicara ke backend ExpressJS, bukan langsung ke Supabase.

# Backend URL — local dev
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:4000
# Backend URL — Railway: gunakan domain PUBLIC backend (bukan private, karena ini di-embed di browser)
# NEXT_PUBLIC_BACKEND_URL=https://backend.railway.app

# Supabase — diperlukan untuk Realtime subscription (status pipeline)
# Ambil dari Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
