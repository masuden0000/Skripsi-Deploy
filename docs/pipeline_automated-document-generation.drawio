<mxfile host="app.diagrams.net" agent="Claude">
  <diagram id="pipeline-adg" name="Pipeline Automated Document Generation">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="1060" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ======================================================= -->
        <!-- TITLE                                                     -->
        <!-- ======================================================= -->
        <mxCell id="title" parent="1"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;"
          value="Pipeline Automated Document Generation" vertex="1">
          <mxGeometry x="30" y="18" width="1000" height="30" as="geometry" />
        </mxCell>

        <!-- ======================================================= -->
        <!-- BAGIAN 0 — HTTP ENTRY LAYER                              -->
        <!-- ======================================================= -->

        <mxCell id="http-label" parent="1"
          style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;"
          value="Bagian 0 — HTTP Entry" vertex="1">
          <mxGeometry x="30" y="58" width="300" height="20" as="geometry" />
        </mxCell>

        <!-- Frontend -->
        <mxCell id="fe" parent="1"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;spacingLeft=8;spacingTop=4;spacingBottom=4;verticalAlign=top;"
          value="&lt;b&gt;Frontend — Next.js :3000&lt;/b&gt;&#xa;────────────────────────────────&#xa;Aksi &nbsp; : User memilih skema PKM dan mengupload file PDF&#xa;File &nbsp; : frontend/lib/backend-api.ts&#xa;Fungsi : proxyToBackend()&#xa;Tujuan : Kirim multipart/form-data + session cookie ke Express" vertex="1">
          <mxGeometry x="30" y="80" width="290" height="95" as="geometry" />
        </mxCell>

        <!-- Express Backend -->
        <mxCell id="exp" parent="1"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;spacingLeft=8;spacingTop=4;spacingBottom=4;verticalAlign=top;"
          value="&lt;b&gt;Express Backend — :4000&lt;/b&gt;&#xa;────────────────────────────────&#xa;Aksi &nbsp; : Verifikasi sesi dan role pengguna, teruskan request&#xa;File &nbsp; : backend/src/routes/projects.routes.js&#xa;Guard &nbsp;: authenticateSession → requireRole&#xa;Tujuan : Proxy raw buffer ke AI Backend tanpa parse ulang" vertex="1">
          <mxGeometry x="380" y="80" width="290" height="95" as="geometry" />
        </mxCell>

        <!-- FastAPI AI Backend -->
        <mxCell id="fapi" parent="1"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;spacingLeft=8;spacingTop=4;spacingBottom=4;verticalAlign=top;"
          value="&lt;b&gt;FastAPI AI Backend — :8000&lt;/b&gt;&#xa;────────────────────────────────&#xa;Aksi &nbsp; : Terima file, upload ke Storage, buat record project&#xa;File &nbsp; : ai/backend/routers/projects.py&#xa;Fungsi : create_project()&#xa;Tujuan : Daftarkan run_pipeline sebagai background task" vertex="1">
          <mxGeometry x="730" y="80" width="290" height="95" as="geometry" />
        </mxCell>

        <!-- Arrow: Frontend → Express -->
        <mxCell id="arr-fe-exp" parent="1" edge="1" source="fe" target="exp"
          style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#000000;fontSize=9;"
          value="multipart + cookie">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: Express → FastAPI -->
        <mxCell id="arr-exp-fapi" parent="1" edge="1" source="exp" target="fapi"
          style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#000000;fontSize=9;"
          value="raw buffer proxy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ======================================================= -->
        <!-- FASE 1 CONTAINER                                          -->
        <!-- ======================================================= -->

        <mxCell id="fase1-bg" parent="1"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;"
          value="Fase 1 — Extraction Pipeline &nbsp;&nbsp;&nbsp; ai/backend/services/pipeline.py → run_pipeline()" vertex="1">
          <mxGeometry x="30" y="210" width="1000" height="600" as="geometry" />
        </mxCell>

        <!-- Arrow: FastAPI → Step 1 -->
        <mxCell id="arr-fapi-s1" parent="1" edge="1" source="fapi" target="s1"
          style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#000000;fontSize=9;"
          value="BackgroundTasks.add_task(run_pipeline)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 1: Download -->
        <mxCell id="s1" parent="1"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;spacingLeft=8;spacingTop=4;spacingBottom=4;verticalAlign=top;"
          value="&lt;b&gt;Step 1 — Download File Sumber&lt;/b&gt;&#xa;────────────────────────────────&#xa;Aksi &nbsp; : Unduh file PDF dari Supabase Storage ke lokal&#xa;File &nbsp; : ai/backend/services/pipeline.py&#xa;Fungsi : download_source_file()&#xa;Sumber : Bucket ai-source-files / {project_id} / {source_file}&#xa;Simpan : ai/model/data/{project_id}/source.pdf" vertex="1">
          <mxGeometry x="70" y="268" width="920" height="95" as="geometry" />
        </mxCell>

        <!-- Step 2: Setup -->
        <mxCell id="s2" parent="1"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;spacingLeft=8;spacingTop=4;spacingBottom=4;verticalAlign=top;"
          value="&lt;b&gt;Step 2 — Chunking dan Embedding (subprocess: manage.py setup)&lt;/b&gt;&#xa;────────────────────────────────&#xa;Aksi &nbsp; : Pecah PDF menjadi chunks teks, generate vektor embedding, simpan ke database&#xa;File ① : ai/model/model_ai/loader/pdf_extractor.py&#xa;Fungsi①: extract_chunks() — pymupdf4llm → MarkdownTextSplitter, deteksi BAB via TOC atau HEADING regex&#xa;File ② : ai/model/model_ai/loader/supabase_ingest.py&#xa;Fungsi②: upsert_embeddings() — Gemini embedding-001, batch 20 chunk per request&#xa;Tulis &nbsp;: Supabase table document_chunks (pgvector, upsert on project_id + chunk_index)" vertex="1">
          <mxGeometry x="70" y="383" width="920" height="120" as="geometry" />
        </mxCell>

        <!-- Step 3: Extraction -->
        <mxCell id="s3" parent="1"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;spacingLeft=8;spacingTop=4;spacingBottom=4;verticalAlign=top;"
          value="&lt;b&gt;Step 3 — Ekstraksi Metadata (subprocess: manage.py extract --skema)&lt;/b&gt;&#xa;────────────────────────────────&#xa;Aksi &nbsp; : Jalankan RAG query per key metadata, kirim ke LLM, simpan hasil terstruktur&#xa;File &nbsp; : ai/model/model_ai/extractor/doc_extractor.py&#xa;Fungsi : extract_document_metadata() → loop _extract_key() untuk 8 key per skema PKM&#xa;Alur &nbsp; : vector search document_chunks → render prompt → LLM.with_structured_output(PydanticModel)&#xa;LLM &nbsp; : Groq llama-3.3-70b (primary) — rotasi key — fallback ke Gemini 2.5 Flash&#xa;Tulis &nbsp;: Supabase table document_metadata (kolom payload JSON, upsert on project_id)" vertex="1">
          <mxGeometry x="70" y="523" width="920" height="120" as="geometry" />
        </mxCell>

        <!-- Step 4: Placeholder -->
        <mxCell id="s4" parent="1"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;spacingLeft=8;spacingTop=4;spacingBottom=4;verticalAlign=top;"
          value="&lt;b&gt;Step 4 — Generate Instructional Placeholder (subprocess: manage.py generate-placeholders)&lt;/b&gt;&#xa;────────────────────────────────&#xa;Aksi &nbsp; : Generate teks panduan isi per section dokumen menggunakan LLM&#xa;File &nbsp; : ai/model/model_ai/docx/instructional_placeholder_builder.py&#xa;Fungsi : build_instructional_placeholder_map() → save_generated_placeholders()&#xa;Tulis &nbsp;: document_metadata.payload.document_structure_proposal.generated_placeholders" vertex="1">
          <mxGeometry x="70" y="663" width="920" height="95" as="geometry" />
        </mxCell>

        <!-- Status: extracted -->
        <mxCell id="s-extracted" parent="1"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontSize=10;fontStyle=1;align=center;verticalAlign=middle;"
          value="Status DB: projects.status = 'extracted' — Pipeline berhenti, menunggu konfirmasi user" vertex="1">
          <mxGeometry x="70" y="778" width="920" height="20" as="geometry" />
        </mxCell>

        <!-- Arrows dalam Fase 1 -->
        <mxCell id="arr-s1-s2" parent="1" edge="1" source="s1" target="s2"
          style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#000000;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr-s2-s3" parent="1" edge="1" source="s2" target="s3"
          style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#000000;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr-s3-s4" parent="1" edge="1" source="s3" target="s4"
          style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#000000;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr-s4-ext" parent="1" edge="1" source="s4" target="s-extracted"
          style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#000000;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ======================================================= -->
        <!-- USER CONFIRMATION                                         -->
        <!-- ======================================================= -->

        <mxCell id="user-confirm" parent="1"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=2;fontSize=10;align=left;spacingLeft=8;spacingTop=4;spacingBottom=4;verticalAlign=top;"
          value="&lt;b&gt;Konfirmasi User&lt;/b&gt;&#xa;────────────────────────────────&#xa;Aksi &nbsp; : User membaca hasil ekstraksi, dapat mengedit nilai, lalu menekan Generate Dokumen&#xa;Request: POST /api/projects/{id}/generate&#xa;Alur &nbsp; : Frontend → Express (auth guard) → FastAPI → BackgroundTasks.add_task(run_docx_pipeline)" vertex="1">
          <mxGeometry x="30" y="838" width="1000" height="80" as="geometry" />
        </mxCell>

        <!-- Arrow: status extracted → user confirm -->
        <mxCell id="arr-ext-user" parent="1" edge="1" source="s-extracted" target="user-confirm"
          style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#000000;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ======================================================= -->
        <!-- FASE 2 CONTAINER                                          -->
        <!-- ======================================================= -->

        <mxCell id="fase2-bg" parent="1"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;fontSize=11;fontStyle=1;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;"
          value="Fase 2 — DOCX Generation &nbsp;&nbsp;&nbsp; ai/backend/services/pipeline.py → run_docx_pipeline()" vertex="1">
          <mxGeometry x="30" y="948" width="1000" height="518" as="geometry" />
        </mxCell>

        <!-- Arrow: user confirm → Step 5 -->
        <mxCell id="arr-user-s5" parent="1" edge="1" source="user-confirm" target="s5"
          style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#000000;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 5: DOCX Generation -->
        <mxCell id="s5" parent="1"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;spacingLeft=8;spacingTop=4;spacingBottom=4;verticalAlign=top;"
          value="&lt;b&gt;Step 5 — Generate Dokumen DOCX (subprocess: manage.py docx --type proposal --skema)&lt;/b&gt;&#xa;────────────────────────────────&#xa;Aksi &nbsp; : Rakit dokumen DOCX dari metadata, chunks, dan placeholder yang tersimpan di database&#xa;File &nbsp; : ai/model/model_ai/docx/generator.py&#xa;Fungsi : generate_proposal_docx_bytes()&#xa;Baca ① : load_document_metadata() — dari Supabase table document_metadata&#xa;Baca ② : load_chunk_sources() — dari Supabase table document_chunks&#xa;Merge &nbsp;: generated_placeholders + user_placeholders (nilai user menimpa nilai generate)&#xa;Routing: is_type_b(skema)? → docx_B_renderer.py (PKM-AI) : docx_A_renderer.py (semua skema lain)&#xa;Output : DOCX bytes di memori, tidak pernah ditulis ke disk" vertex="1">
          <mxGeometry x="70" y="1005" width="920" height="145" as="geometry" />
        </mxCell>

        <!-- Step 6: Upload -->
        <mxCell id="s6" parent="1"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;spacingLeft=8;spacingTop=4;spacingBottom=4;verticalAlign=top;"
          value="&lt;b&gt;Step 6 — Upload File DOCX ke Storage&lt;/b&gt;&#xa;────────────────────────────────&#xa;Aksi &nbsp; : Upload bytes DOCX langsung ke Supabase Storage&#xa;File &nbsp; : ai/model/model_ai/storage.py&#xa;Fungsi : upload_docx_to_storage()&#xa;Simpan : Bucket ai-output-files / {project_id} / {filename}.docx&#xa;Output : Public URL file DOCX (dicetak sebagai RESULT_URL=... ke stdout subprocess)" vertex="1">
          <mxGeometry x="70" y="1170" width="920" height="100" as="geometry" />
        </mxCell>

        <!-- Step 7: Update DB -->
        <mxCell id="s7" parent="1"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;spacingLeft=8;spacingTop=4;spacingBottom=4;verticalAlign=top;"
          value="&lt;b&gt;Step 7 — Update Status Project di Database&lt;/b&gt;&#xa;────────────────────────────────&#xa;Aksi &nbsp; : Catat URL hasil dokumen dan tandai project sebagai selesai&#xa;File &nbsp; : ai/backend/services/pipeline.py&#xa;Tulis &nbsp;: projects.result_url = RESULT_URL (public URL Supabase Storage)&#xa;Tulis &nbsp;: projects.status = 'completed'" vertex="1">
          <mxGeometry x="70" y="1290" width="920" height="90" as="geometry" />
        </mxCell>

        <!-- Step 8: Cleanup -->
        <mxCell id="s8" parent="1"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=10;align=left;spacingLeft=8;spacingTop=4;spacingBottom=4;verticalAlign=top;"
          value="&lt;b&gt;Step 8 — Hapus File Sementara Lokal&lt;/b&gt;&#xa;────────────────────────────────&#xa;Aksi &nbsp; : Hapus seluruh folder kerja lokal agar tidak menumpuk di server&#xa;File &nbsp; : ai/backend/services/pipeline.py&#xa;Fungsi : _cleanup_project_data()&#xa;Hapus &nbsp;: ai/model/data/{project_id}/ (source.pdf, output_chunks.json, output.md)" vertex="1">
          <mxGeometry x="70" y="1400" width="920" height="56" as="geometry" />
        </mxCell>

        <!-- Arrows dalam Fase 2 -->
        <mxCell id="arr-s5-s6" parent="1" edge="1" source="s5" target="s6"
          style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#000000;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr-s6-s7" parent="1" edge="1" source="s6" target="s7"
          style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#000000;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr-s7-s8" parent="1" edge="1" source="s7" target="s8"
          style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;strokeColor=#000000;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
